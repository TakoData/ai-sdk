{
  "name": "@takoviz/ai-sdk",
  "version": "1.0.1",
  "description": "Tako knowledge search, answer, and contents tools for the Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["tako", "knowledge-search", "ai-sdk", "vercel", "data-visualization", "ai", "tools"],
  "author": "Tako",
  "license": "MIT",
  "homepage": "https://tako.com",
  "repository": { "type": "git", "url": "git+https://github.com/TakoData/ai-sdk.git" },
  "bugs": { "url": "https://github.com/TakoData/ai-sdk/issues" },
  "packageManager": "pnpm@11.9.0",
  "peerDependencies": {
    "ai": "^6.0.18",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.7",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
